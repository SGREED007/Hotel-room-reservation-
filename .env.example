# Environment Configuration
# Copy this file to .env and update with your values

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# Database (SQLite for development, PostgreSQL for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/hotel_db

# Email Configuration (Optional - for sending booking confirmations)
# Get app password from: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Payment Gateway (Future implementation)
# RAZORPAY_KEY_ID=your_razorpay_key
# RAZORPAY_KEY_SECRET=your_razorpay_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8000

# Admin Email (for initial admin account)
ADMIN_EMAIL=admin@grandvista.com
ADMIN_PASSWORD=admin123
